{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.34,
      "to": 2.22,
      "sid": 1,
      "location": 2,
      "content": "我在一个10万行代码的项目里",
      "music": 0.0
    },
    {
      "from": 2.22,
      "to": 4.18,
      "sid": 2,
      "location": 2,
      "content": "只让AI替换一个侧边栏图标",
      "music": 0.0
    },
    {
      "from": 4.18,
      "to": 6.36,
      "sid": 3,
      "location": 2,
      "content": "第一轮我只告诉他我最终的需求",
      "music": 0.0
    },
    {
      "from": 6.36,
      "to": 8.22,
      "sid": 4,
      "location": 2,
      "content": "但他自己从整个项目里面找",
      "music": 0.0
    },
    {
      "from": 8.22,
      "to": 10.05,
      "sid": 5,
      "location": 2,
      "content": "前后花了大约30分钟",
      "music": 0.0
    },
    {
      "from": 10.05,
      "to": 12.55,
      "sid": 6,
      "location": 2,
      "content": "第二轮我直接给出相关文件的入口",
      "music": 0.0
    },
    {
      "from": 12.55,
      "to": 14.2,
      "sid": 7,
      "location": 2,
      "content": "时间降到了14分钟",
      "music": 0.0
    },
    {
      "from": 14.2,
      "to": 16.46,
      "sid": 8,
      "location": 2,
      "content": "第三轮我保留同样的文件入口",
      "music": 0.0
    },
    {
      "from": 16.46,
      "to": 17.36,
      "sid": 9,
      "location": 2,
      "content": "再把图片处理",
      "music": 0.0
    },
    {
      "from": 17.36,
      "to": 19.84,
      "sid": 10,
      "location": 2,
      "content": "这套重复流程固化成项目级的skill",
      "music": 0.0
    },
    {
      "from": 19.84,
      "to": 21.95,
      "sid": 11,
      "location": 2,
      "content": "默认速度下大约10分钟",
      "music": 0.0
    },
    {
      "from": 21.95,
      "to": 22.95,
      "sid": 12,
      "location": 2,
      "content": "模型没有换",
      "music": 0.0
    },
    {
      "from": 22.95,
      "to": 24.41,
      "sid": 13,
      "location": 2,
      "content": "任务类型也没有换",
      "music": 0.0
    },
    {
      "from": 24.41,
      "to": 27.67,
      "sid": 14,
      "location": 2,
      "content": "真正改变的是我减少了AI的两种不确定性",
      "music": 0.0
    },
    {
      "from": 27.67,
      "to": 28.85,
      "sid": 15,
      "location": 2,
      "content": "他要去哪里找",
      "music": 0.0
    },
    {
      "from": 28.85,
      "to": 30.6,
      "sid": 16,
      "location": 2,
      "content": "以及找到以后应该怎么做",
      "music": 0.0
    },
    {
      "from": 30.6,
      "to": 32.74,
      "sid": 17,
      "location": 2,
      "content": "这期我就用这三轮真实的记录",
      "music": 0.0
    },
    {
      "from": 32.74,
      "to": 35.88,
      "sid": 18,
      "location": 2,
      "content": "讲清楚单项目里怎样让AI修改简单需求时",
      "music": 0.0
    },
    {
      "from": 35.88,
      "to": 36.92,
      "sid": 19,
      "location": 2,
      "content": "少做点探索",
      "music": 0.0
    },
    {
      "from": 36.92,
      "to": 38.17,
      "sid": 20,
      "location": 2,
      "content": "多做执行",
      "music": 0.0
    },
    {
      "from": 38.17,
      "to": 40.67,
      "sid": 21,
      "location": 2,
      "content": "对症下药的前提是弄清楚根本原因",
      "music": 0.0
    },
    {
      "from": 40.67,
      "to": 41.95,
      "sid": 22,
      "location": 2,
      "content": "为什么小项目快",
      "music": 0.0
    },
    {
      "from": 41.95,
      "to": 43.44,
      "sid": 23,
      "location": 2,
      "content": "大项目却越来越慢",
      "music": 0.0
    },
    {
      "from": 43.44,
      "to": 45.44,
      "sid": 24,
      "location": 2,
      "content": "项目刚开始的时候代码量小",
      "music": 0.0
    },
    {
      "from": 45.44,
      "to": 46.46,
      "sid": 25,
      "location": 2,
      "content": "目录也简单",
      "music": 0.0
    },
    {
      "from": 46.46,
      "to": 48.6,
      "sid": 26,
      "location": 2,
      "content": "你告诉AI把这个图标换掉",
      "music": 0.0
    },
    {
      "from": 48.6,
      "to": 50.35,
      "sid": 27,
      "location": 2,
      "content": "它可能23分钟就做完了",
      "music": 0.0
    },
    {
      "from": 50.35,
      "to": 52.81,
      "sid": 28,
      "location": 2,
      "content": "但项目增长到接近10万行代码以后",
      "music": 0.0
    },
    {
      "from": 52.81,
      "to": 55.78,
      "sid": 29,
      "location": 2,
      "content": "同样一句话背后的搜索空间已经完全不同",
      "music": 0.0
    },
    {
      "from": 55.78,
      "to": 57.36,
      "sid": 30,
      "location": 2,
      "content": "你眼里只是一张图片",
      "music": 0.0
    },
    {
      "from": 57.36,
      "to": 60.2,
      "sid": 31,
      "location": 2,
      "content": "当AI并不知道这个图标有没有主题切换",
      "music": 0.0
    },
    {
      "from": 60.2,
      "to": 61.62,
      "sid": 32,
      "location": 2,
      "content": "有没有什么共享的样式",
      "music": 0.0
    },
    {
      "from": 61.62,
      "to": 63.09,
      "sid": 33,
      "location": 2,
      "content": "或是直接引用的资源",
      "music": 0.0
    },
    {
      "from": 63.09,
      "to": 65.17,
      "sid": 34,
      "location": 2,
      "content": "还是由组件动态渲染",
      "music": 0.0
    },
    {
      "from": 65.17,
      "to": 66.75,
      "sid": 35,
      "location": 2,
      "content": "为了确认影响范围",
      "music": 0.0
    },
    {
      "from": 66.75,
      "to": 69.03,
      "sid": 36,
      "location": 2,
      "content": "他可能会继续查找资源的定义",
      "music": 0.0
    },
    {
      "from": 69.03,
      "to": 70.27,
      "sid": 37,
      "location": 2,
      "content": "组建入口样式",
      "music": 0.0
    },
    {
      "from": 70.27,
      "to": 71.05,
      "sid": 38,
      "location": 2,
      "content": "主题逻辑",
      "music": 0.0
    },
    {
      "from": 71.05,
      "to": 74.21,
      "sid": 39,
      "location": 2,
      "content": "甚至读到一些与这次改动关系不大的文档",
      "music": 0.0
    },
    {
      "from": 74.21,
      "to": 76.07,
      "sid": 40,
      "location": 2,
      "content": "这些检查不一定是错的",
      "music": 0.0
    },
    {
      "from": 76.07,
      "to": 78.69,
      "sid": 41,
      "location": 2,
      "content": "问题在于对于一个很局部的图标替换",
      "music": 0.0
    },
    {
      "from": 78.69,
      "to": 80.68,
      "sid": 42,
      "location": 2,
      "content": "它的大量时间并没有花在改",
      "music": 0.0
    },
    {
      "from": 80.68,
      "to": 82.1,
      "sid": 43,
      "location": 2,
      "content": "而是无法在寻找链路",
      "music": 0.0
    },
    {
      "from": 82.1,
      "to": 83.68,
      "sid": 44,
      "location": 2,
      "content": "探索代码和不断的推理",
      "music": 0.0
    },
    {
      "from": 83.68,
      "to": 85.49,
      "sid": 45,
      "location": 2,
      "content": "直到确认链路走通",
      "music": 0.0
    },
    {
      "from": 85.49,
      "to": 87.61,
      "sid": 46,
      "location": 2,
      "content": "第一轮实测只描述结果",
      "music": 0.0
    },
    {
      "from": 87.61,
      "to": 88.45,
      "sid": 47,
      "location": 2,
      "content": "让AI自己找",
      "music": 0.0
    },
    {
      "from": 88.45,
      "to": 90.24,
      "sid": 48,
      "location": 2,
      "content": "总共耗时30分钟",
      "music": 0.0
    },
    {
      "from": 90.24,
      "to": 93.02,
      "sid": 49,
      "location": 2,
      "content": "我只给了项目根目录需要替换的图片",
      "music": 0.0
    },
    {
      "from": 93.02,
      "to": 94.92,
      "sid": 50,
      "location": 2,
      "content": "以及它在UI上的大概的位置",
      "music": 0.0
    },
    {
      "from": 94.92,
      "to": 96.699,
      "sid": 51,
      "location": 2,
      "content": "这是我的提示词",
      "music": 0.0
    },
    {
      "from": 96.699,
      "to": 98.639,
      "sid": 52,
      "location": 2,
      "content": "这是一种很自然的使用方式",
      "music": 0.0
    },
    {
      "from": 98.639,
      "to": 102.1,
      "sid": 53,
      "location": 2,
      "content": "也是很多人刚开始用AI编程最常用的方式",
      "music": 0.0
    },
    {
      "from": 102.1,
      "to": 103.46,
      "sid": 54,
      "location": 2,
      "content": "但在大项目里",
      "music": 0.0
    },
    {
      "from": 103.46,
      "to": 105.02,
      "sid": 55,
      "location": 2,
      "content": "他等于把定位代码完成",
      "music": 0.0
    },
    {
      "from": 105.02,
      "to": 106.27,
      "sid": 56,
      "location": 2,
      "content": "修改两个任务",
      "music": 0.0
    },
    {
      "from": 106.27,
      "to": 107.29,
      "sid": 57,
      "location": 2,
      "content": "同时就为了AI",
      "music": 0.0
    },
    {
      "from": 107.29,
      "to": 110.15,
      "sid": 58,
      "location": 2,
      "content": "这一轮他先花了大约11分钟分析和定位",
      "music": 0.0
    },
    {
      "from": 110.15,
      "to": 111.87,
      "sid": 59,
      "location": 2,
      "content": "随后用了十几分钟处理资源",
      "music": 0.0
    },
    {
      "from": 111.87,
      "to": 114.509,
      "sid": 60,
      "location": 2,
      "content": "修改代码验证这个过程将近30分钟",
      "music": 0.0
    },
    {
      "from": 114.509,
      "to": 116.949,
      "sid": 61,
      "location": 2,
      "content": "所以第一轮实测真是暴露的问题",
      "music": 0.0
    },
    {
      "from": 116.949,
      "to": 119.129,
      "sid": 62,
      "location": 2,
      "content": "是给AI的任务边界太开放",
      "music": 0.0
    },
    {
      "from": 119.129,
      "to": 122.74,
      "sid": 63,
      "location": 2,
      "content": "它必须先重新认识与这个图标有关的局部系统",
      "music": 0.0
    },
    {
      "from": 122.74,
      "to": 123.98,
      "sid": 64,
      "location": 2,
      "content": "才敢开始修改",
      "music": 0.0
    },
    {
      "from": 125.1,
      "to": 126.96,
      "sid": 65,
      "location": 2,
      "content": "第二轮实测是给他项目地图",
      "music": 0.0
    },
    {
      "from": 126.96,
      "to": 128.48,
      "sid": 66,
      "location": 2,
      "content": "不是把它锁死嗯",
      "music": 0.0
    },
    {
      "from": 128.48,
      "to": 129.76,
      "sid": 67,
      "location": 2,
      "content": "总耗时14分钟",
      "music": 0.0
    },
    {
      "from": 129.76,
      "to": 131.32,
      "sid": 68,
      "location": 2,
      "content": "第二轮主要改变一件事",
      "music": 0.0
    },
    {
      "from": 131.32,
      "to": 133.16,
      "sid": 69,
      "location": 2,
      "content": "就是在描述需求的同时",
      "music": 0.0
    },
    {
      "from": 133.16,
      "to": 136.04,
      "sid": 70,
      "location": 2,
      "content": "把高概率相关的文件和目录直接告诉他",
      "music": 0.0
    },
    {
      "from": 136.04,
      "to": 137.94,
      "sid": 71,
      "location": 2,
      "content": "这里要特别区分两个概念",
      "music": 0.0
    },
    {
      "from": 137.94,
      "to": 142.02,
      "sid": 72,
      "location": 2,
      "content": "不是强行规定AI只能读取或修改三个文件范围",
      "music": 0.0
    },
    {
      "from": 142.02,
      "to": 142.74,
      "sid": 73,
      "location": 2,
      "content": "卡的太死",
      "music": 0.0
    },
    {
      "from": 142.74,
      "to": 145.38,
      "sid": 74,
      "location": 2,
      "content": "如果真实依赖恰好在第四个文件",
      "music": 0.0
    },
    {
      "from": 145.38,
      "to": 147.48,
      "sid": 75,
      "location": 2,
      "content": "就有可能过快却改错了文件",
      "music": 0.0
    },
    {
      "from": 147.48,
      "to": 149.82,
      "sid": 76,
      "location": 2,
      "content": "我做的是给他几个明确入口",
      "music": 0.0
    },
    {
      "from": 149.82,
      "to": 153.63,
      "sid": 77,
      "location": 2,
      "content": "先检查哪个组件资源通常放在哪个目录样",
      "music": 0.0
    },
    {
      "from": 153.63,
      "to": 155.68,
      "sid": 78,
      "location": 2,
      "content": "相关的样式大概率在哪个文件",
      "music": 0.0
    },
    {
      "from": 155.68,
      "to": 157.76,
      "sid": 79,
      "location": 2,
      "content": "如果确实发现了其他直接依赖",
      "music": 0.0
    },
    {
      "from": 157.76,
      "to": 159.58,
      "sid": 80,
      "location": 2,
      "content": "再根据证据扩展范围",
      "music": 0.0
    },
    {
      "from": 159.58,
      "to": 160.2,
      "sid": 81,
      "location": 2,
      "content": "这样一来",
      "music": 0.0
    },
    {
      "from": 160.2,
      "to": 162.84,
      "sid": 82,
      "location": 2,
      "content": "原本的大范围搜索就变成了局部确认",
      "music": 0.0
    },
    {
      "from": 162.84,
      "to": 165.36,
      "sid": 83,
      "location": 2,
      "content": "这一轮AI的文件读取分析和修改",
      "music": 0.0
    },
    {
      "from": 165.36,
      "to": 167.38,
      "sid": 84,
      "location": 2,
      "content": "基本都围绕我给的入口展开",
      "music": 0.0
    },
    {
      "from": 167.38,
      "to": 170.76,
      "sid": 85,
      "location": 2,
      "content": "总耗时从接近30分钟降到了大约14分钟",
      "music": 0.0
    },
    {
      "from": 170.76,
      "to": 172.08,
      "sid": 86,
      "location": 2,
      "content": "所以你即使不懂一行",
      "music": 0.0
    },
    {
      "from": 172.08,
      "to": 172.86,
      "sid": 87,
      "location": 2,
      "content": "每一行代码",
      "music": 0.0
    },
    {
      "from": 172.86,
      "to": 175.48,
      "sid": 88,
      "location": 2,
      "content": "也最好对项目目录和主要文件的脉络",
      "music": 0.0
    },
    {
      "from": 175.48,
      "to": 176.66,
      "sid": 89,
      "location": 2,
      "content": "有一个基本的印象",
      "music": 0.0
    },
    {
      "from": 176.66,
      "to": 178.46,
      "sid": 90,
      "location": 2,
      "content": "你不需要替AI写代码",
      "music": 0.0
    },
    {
      "from": 178.46,
      "to": 180.34,
      "sid": 91,
      "location": 2,
      "content": "但可以把自己已经知道的",
      "music": 0.0
    },
    {
      "from": 180.34,
      "to": 183.46,
      "sid": 92,
      "location": 2,
      "content": "项目的主要脉络和背景交给他",
      "music": 0.0
    },
    {
      "from": 183.46,
      "to": 186.149,
      "sid": 93,
      "location": 2,
      "content": "不要让他每次都从零开始去猜",
      "music": 0.0
    },
    {
      "from": 186.149,
      "to": 188.109,
      "sid": 94,
      "location": 2,
      "content": "以后做这类局部任务",
      "music": 0.0
    },
    {
      "from": 188.109,
      "to": 190.56,
      "sid": 95,
      "location": 2,
      "content": "可以大概分为四个部分",
      "music": 0.0
    },
    {
      "from": 190.56,
      "to": 193.26,
      "sid": 96,
      "location": 2,
      "content": "第一就是你的目标是什么",
      "music": 0.0
    },
    {
      "from": 193.26,
      "to": 194.82,
      "sid": 97,
      "location": 2,
      "content": "第二就是从哪里开始找",
      "music": 0.0
    },
    {
      "from": 194.82,
      "to": 197.3,
      "sid": 98,
      "location": 2,
      "content": "给出高概率相关的组件样式",
      "music": 0.0
    },
    {
      "from": 197.3,
      "to": 198.84,
      "sid": 99,
      "location": 2,
      "content": "文件和资源目录",
      "music": 0.0
    },
    {
      "from": 198.84,
      "to": 201.5,
      "sid": 100,
      "location": 2,
      "content": "第三是执行时遵守什么规范",
      "music": 0.0
    },
    {
      "from": 201.5,
      "to": 204.269,
      "sid": 101,
      "location": 2,
      "content": "比如用什么什么样的图标尺寸",
      "music": 0.0
    },
    {
      "from": 204.269,
      "to": 205.969,
      "sid": 102,
      "location": 2,
      "content": "命名和引用方式等",
      "music": 0.0
    },
    {
      "from": 205.969,
      "to": 207.389,
      "sid": 103,
      "location": 2,
      "content": "第四怎样才算完成",
      "music": 0.0
    },
    {
      "from": 207.389,
      "to": 209.229,
      "sid": 104,
      "location": 2,
      "content": "比如说透明背景正确",
      "music": 0.0
    },
    {
      "from": 209.229,
      "to": 210.64,
      "sid": 105,
      "location": 2,
      "content": "或者说界面显示一致",
      "music": 0.0
    },
    {
      "from": 210.64,
      "to": 211.92,
      "sid": 106,
      "location": 2,
      "content": "构建验证",
      "music": 0.0
    },
    {
      "from": 211.92,
      "to": 213.5,
      "sid": 107,
      "location": 2,
      "content": "等你实测等等",
      "music": 0.0
    },
    {
      "from": 213.5,
      "to": 216.26,
